<Window x:Class="PyOCR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyOCR.ViewModel"
        xmlns:behaviors="clr-namespace:PyOCR.Behaviors"
        xmlns:converters="clr-namespace:PyOCR.Converters"
        mc:Ignorable="d"
        Title="PyOCR — Text Recognition"
        Height="640" Width="980"
        MinWidth="720" MinHeight="480"
        Background="#F1F5F9">

    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F6BF4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A56E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D44C8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#C7CEEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Drop zone style — reacts to IsDragOver attached property -->
        <Style x:Key="DropZoneStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=(behaviors:DropBehavior.IsDragOver),
                                               RelativeSource={RelativeSource Self}}"
                             Value="True">
                    <Setter Property="BorderBrush" Value="#4F6BF4"/>
                    <Setter Property="Background" Value="#EEF2FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16,16,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT PANEL: Drop Zone ===== -->
        <Border Grid.Column="0" Grid.Row="0"
                Style="{StaticResource DropZoneStyle}"
                behaviors:DropBehavior.DropCommand="{Binding ProcessImageCommand}">

            <!-- Click to browse -->
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding BrowseCommand}"/>
            </Border.InputBindings>

            <Grid>
                <!-- Placeholder: visible when no image loaded -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="24"
                            Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}">
                    <Border Background="#EEF2FF" CornerRadius="36"
                            Width="72" Height="72"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Viewbox Width="36" Height="36">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="2" Canvas.Top="3"
                                           Width="20" Height="18" RadiusX="2" RadiusY="2"
                                           Stroke="#6366F1" StrokeThickness="1.5"
                                           Fill="Transparent"/>
                                <Ellipse Canvas.Left="7" Canvas.Top="7"
                                         Width="4" Height="4" Fill="#6366F1"/>
                                <Polyline Points="2,19 7,13 11,17 15,12 22,19"
                                          Stroke="#6366F1" StrokeThickness="1.5"
                                          StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Drag &amp; drop an image here"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#334155"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="or click to browse files"
                               FontSize="12" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                    <Border Background="#F8FAFC" CornerRadius="6"
                            Padding="10,5" Margin="0,14,0,0"
                            HorizontalAlignment="Center">
                        <TextBlock Text="PNG  ·  JPG  ·  BMP  ·  TIFF  ·  WebP"
                                   FontSize="11" Foreground="#94A3B8"/>
                    </Border>
                </StackPanel>

                <!-- Image preview: visible when image is loaded -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                    <Image Source="{Binding PreviewSource}"
                           Stretch="Uniform"
                           Margin="12"/>
                    <Button Content="Change Image"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding BrowseCommand}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12"/>
                </Grid>

                <!-- Processing overlay -->
                <Border Background="#B2FFFFFF"
                        CornerRadius="12"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Processing..."
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#4F6BF4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ===== RIGHT PANEL: Text Output ===== -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Extracted Text"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E293B"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Clear"
                            Style="{StaticResource GhostButton}"
                            FontSize="11" Padding="10,5"
                            Command="{Binding ClearCommand}"/>
                </Grid>

                <!-- Text area with placeholder overlay -->
                <Border Grid.Row="1"
                        Background="#F8FAFC"
                        CornerRadius="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <Grid>
                        <!-- Placeholder -->
                        <TextBlock Text="OCR output will appear here..."
                                   FontSize="13" FontFamily="Consolas"
                                   Foreground="#94A3B8"
                                   Padding="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"
                                   Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVis}}"/>
                        <!-- Result (selectable, copyable) -->
                        <TextBox Text="{Binding OcrText, Mode=OneWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 FontFamily="Consolas"
                                 Foreground="#1E293B"
                                 Padding="12"
                                 Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding CharCount}"
                               FontSize="11" Foreground="#94A3B8"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Copy Text"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CopyCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3"
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#64748B"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding StatusDotBrush}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ServerStatusLabel}"
                               FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
